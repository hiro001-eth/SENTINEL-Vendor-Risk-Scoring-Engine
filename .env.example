# ──────────────────────────────────────────────────────────────────────────────
# SENTINEL GRC — Environment Configuration Template
# Copy to .env and fill in your values before running.
# ──────────────────────────────────────────────────────────────────────────────

# ── Schema Paths (Required) ───────────────────────────────────────────────────
QUESTIONNAIRE_SCHEMA_PATH=./src/vendor_risk_engine/rules/questionnaire_schema.yaml
WEIGHT_CONFIG_PATH=./src/vendor_risk_engine/rules/weight_config.yaml
THRESHOLD_CONFIG_PATH=./src/vendor_risk_engine/rules/threshold_config.yaml

# ── External API Keys (Optional — pipeline runs in fallback mode without them) 
BITSIGHT_API_KEY=
SECURITYSCORECARD_API_KEY=
HIBP_API_KEY=

# ── External Data Freshness ───────────────────────────────────────────────────
EXTERNAL_DATA_TTL_HOURS=168

# ── Scoring Engine ────────────────────────────────────────────────────────────
SCORING_DECIMAL_PLACES=4
BATCH_SIZE=100
CATEGORY_FLOOR_ENABLED=true

# ── Reporting ─────────────────────────────────────────────────────────────────
REPORT_FONT_PATH=./assets/fonts
REPORT_LOGO_PATH=./assets/logo.png
PDF_A_COMPLIANCE=true
OUTPUT_DIR=./output

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ASSESSMENT_RUN_ID_PREFIX=SENTINEL

# ── Webhook Notifications (Optional) ─────────────────────────────────────────
# Supported providers: slack | teams | generic
# Leave WEBHOOK_URL blank to disable notifications entirely.
#
# Slack example:
#   WEBHOOK_URL=https://your-webhook-domain.com/services/TXXXXX/BXXXXX/XXXXX
#   WEBHOOK_PROVIDER=slack
#
# Microsoft Teams example:
#   WEBHOOK_URL=https://yourtenant.webhook.office.com/webhookb2/...
#   WEBHOOK_PROVIDER=teams
#
WEBHOOK_URL=
WEBHOOK_PROVIDER=slack
